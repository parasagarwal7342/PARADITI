# P Λ R Λ D I T I – copy to .env and adjust

# Flask
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_SECRET_KEY=change-this-jwt-secret-in-production

# Security & Ledger
# Generate a key using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Database (default: SQLite in instance/sahaj.db)
# DATABASE_URL=sqlite:///sahaj.db

# ML: use TF-IDF only (no sentence-transformers download). Set to 1 for lighter setup.
USE_TFIDF=0
# ML_MODEL_NAME=all-MiniLM-L6-v2
# SIMILARITY_THRESHOLD=0.3

# CORS (comma-separated origins)
# CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Redis (Optional: Fallback to Memory if not set)
REDIS_URL=redis://localhost:6379/0

# API Setu (apisetu.gov.in) – scheme data
API_SETU_BASE_URL=https://directory.apisetu.gov.in
API_SETU_API_KEY=
